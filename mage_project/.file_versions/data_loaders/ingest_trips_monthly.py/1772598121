import os
import pandas as pd
import requests
from datetime import datetime
from sqlalchemy import create_engine, text
import tempfile
import pyarrow.parquet as pq

def tlc_parquet_url(service_type: str, ym: str) -> str:
    return f"https://d37ci6vzurychx.cloudfront.net/trip-data/{service_type}_tripdata_{ym}.parquet"

def normalize_columns(df: pd.DataFrame) -> pd.DataFrame:
    df.columns = [c.strip().lower() for c in df.columns]

    rename = {}
    if "tpep_pickup_datetime" in df.columns:
        rename["tpep_pickup_datetime"] = "pickup_datetime"
    if "tpep_dropoff_datetime" in df.columns:
        rename["tpep_dropoff_datetime"] = "dropoff_datetime"
    if "lpep_pickup_datetime" in df.columns:
        rename["lpep_pickup_datetime"] = "pickup_datetime"
    if "lpep_dropoff_datetime" in df.columns:
        rename["lpep_dropoff_datetime"] = "dropoff_datetime"

    df = df.rename(columns=rename)

    expected = [
        "vendorid","pickup_datetime","dropoff_datetime","passenger_count","trip_distance",
        "ratecodeid","store_and_fwd_flag","pulocationid","dolocationid","payment_type",
        "fare_amount","extra","mta_tax","tip_amount","tolls_amount","improvement_surcharge",
        "total_amount","congestion_surcharge","airport_fee"
    ]
    for c in expected:
        if c not in df.columns:
            df[c] = None

    return df[expected].copy()

@data_loader
def load_data(*args, **kwargs):
    months = ["2024-01"]
    #months = [f"{y}-{m:02d}" for y in range(2022, 2026) for m in range(1, 13)]
    services = ["yellow"]  # start with one service to confirm stability

    host = os.environ["POSTGRES_HOST"]
    port = os.environ["POSTGRES_PORT"]
    db   = os.environ["POSTGRES_DB"]
    user = os.environ["POSTGRES_USER"]
    pwd  = os.environ["POSTGRES_PASSWORD"]
    engine = create_engine(f"postgresql+psycopg2://{user}:{pwd}@{host}:{port}/{db}")

    ingest_ts = datetime.utcnow()
    results = []

    with engine.begin() as conn:
        for ym in months:
            for service in services:
                url = tlc_parquet_url(service, ym)
                print(f"[START] Processing {ym} {service} -> {url}")

                try:
                    with requests.get(url, stream=True, timeout=180) as r:
                        if r.status_code == 404:
                            results.append({"year_month": ym, "service_type": service, "status": "missing", "row_count": 0})
                            continue
                        r.raise_for_status()

                        with tempfile.NamedTemporaryFile(suffix=".parquet") as tmp:
                            for chunk in r.iter_content(chunk_size=1024 * 1024):
                                if chunk:
                                    tmp.write(chunk)
                            tmp.flush()
                            print(f"[DOWNLOAD COMPLETE] {ym} {service}")

                            # idempotency (delete once per month/service)
                            print(f"[DELETE] Removing existing rows for {ym} {service}")
                            conn.execute(
                                text("DELETE FROM bronze.trips_raw WHERE source_month = :ym AND service_type = :svc"),
                                {"ym": ym, "svc": service}
                            )

                            pf = pq.ParquetFile(tmp.name)

                            inserted_total = 0
                            batch_size = 100_000

                            for i, batch in enumerate(pf.iter_batches(batch_size=batch_size), start=1):
                                df_batch = batch.to_pandas()
                                df_batch = normalize_columns(df_batch)

                                df_batch["ingest_ts"] = ingest_ts
                                df_batch["source_month"] = ym
                                df_batch["service_type"] = service
                                df_batch["source_file"] = url

                                df_batch.to_sql(
                                    "trips_raw",
                                    con=conn,
                                    schema="bronze",
                                    if_exists="append",
                                    index=False,
                                    method="multi",
                                    chunksize=2_000
                                )

                                inserted_total += len(df_batch)
                                if i % 5 == 0:
                                    print(f"[BATCH] {ym} {service} batches={i} inserted_total={inserted_total:,}")

                            print(f"[INSERT COMPLETE] {ym} {service} inserted_total={inserted_total:,}")
                            results.append({"year_month": ym, "service_type": service, "status": "loaded", "row_count": int(inserted_total)})

                except Exception as e:
                    results.append({"year_month": ym, "service_type": service, "status": "failed", "row_count": 0, "error": str(e)})

    print("[PIPELINE COMPLETE] Bronze ingestion finished")
    return results