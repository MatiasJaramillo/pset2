def tlc_parquet_url(service_type: str, ym: str) -> str:
    return f"https://d37ci6vzurychx.cloudfront.net/trip-data/{service_type}_tripdata_{ym}.parquet"

def normalize_columns(df: pd.DataFrame) -> pd.DataFrame:
    df.columns = [c.strip().lower() for c in df.columns]

    rename = {}
    if "tpep_pickup_datetime" in df.columns:
        rename["tpep_pickup_datetime"] = "pickup_datetime"
    if "tpep_dropoff_datetime" in df.columns:
        rename["tpep_dropoff_datetime"] = "dropoff_datetime"
    if "lpep_pickup_datetime" in df.columns:
        rename["lpep_pickup_datetime"] = "pickup_datetime"
    if "lpep_dropoff_datetime" in df.columns:
        rename["lpep_dropoff_datetime"] = "dropoff_datetime"

    df = df.rename(columns=rename)

    expected = [
        "vendorid","pickup_datetime","dropoff_datetime","passenger_count","trip_distance",
        "ratecodeid","store_and_fwd_flag","pulocationid","dolocationid","payment_type",
        "fare_amount","extra","mta_tax","tip_amount","tolls_amount","improvement_surcharge",
        "total_amount","congestion_surcharge","airport_fee"
    ]
    for c in expected:
        if c not in df.columns:
            df[c] = None

    return df[expected].copy()

