                try:
                    with requests.get(url, stream=True, timeout=180) as r:
                        if r.status_code == 404:
                            results.append({"year_month": ym, "service_type": service, "status": "missing", "row_count": 0})
                            continue
                        r.raise_for_status()

                        with tempfile.NamedTemporaryFile(suffix=".parquet") as tmp:
                            for chunk in r.iter_content(chunk_size=1024 * 1024):  # 1MB chunks
                                if chunk:
                                    tmp.write(chunk)
                            tmp.flush()
                            print(f"[DOWNLOAD COMPLETE] {ym} {service}")

                            # idempotency
                            print(f"[DELETE] Removing existing rows for {ym} {service}")
                            conn.execute(
                                text("DELETE FROM bronze.trips_raw WHERE source_month = :ym AND service_type = :svc"),
                                {"ym": ym, "svc": service}
