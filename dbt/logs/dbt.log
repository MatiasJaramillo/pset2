    columns:
      - name: trip_key
        tests:
          - not_null
          - unique
      - name: pu_zone_key
        tests:
          - relationships:
              to: ref('dim_zone')
              field: zone_key
      - name: do_zone_key
        tests:
          - relationships:
              to: ref('dim_zone')
              field: zone_key
      - name: pickup_date_key
